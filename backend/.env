# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure Cosmos DB
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key
COSMOS_DATABASE=civicai
COSMOS_CONTAINER_INCIDENTS=incidents
COSMOS_CONTAINER_CITIES=cities
COSMOS_CONTAINER_RESOURCES=resources

# Azure Blob Storage
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_CONTAINER_MEDIA=civicai-media

# Azure AI Search
SEARCH_ENDPOINT=https://YOUR_SEARCH.search.windows.net
SEARCH_KEY=your_search_key
SEARCH_INDEX=incidents-index

# Azure Communication Services
ACS_CONNECTION_STRING=endpoint=https://...
ACS_SENDER_EMAIL=DoNotReply@YOUR_DOMAIN.azurecomm.net
ACS_SENDER_PHONE=+1XXXXXXXXXX

# Hedera Hashgraph
HEDERA_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_PRIVATE_KEY=302e020100300506032b6570...
HEDERA_TOPIC_ID=0.0.XXXXXXX
HEDERA_NETWORK=mainnet

# OSRM routing server (self-hosted or public demo)
OSRM_SERVER=http://router.project-osrm.org

# App settings
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
